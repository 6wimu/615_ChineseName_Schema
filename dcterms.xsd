<?xml version="1.0" encoding="UTF-8"?>
<!--
  Project-scoped Dublin Core Terms validation profile.

  This file is intentionally small: it declares only the two global elements
  reused by cn_schema.xsd. The namespace and element semantics follow DCMI
  Metadata Terms, while the local copy keeps classroom and GitHub Pages
  validation independent of network availability. It is not presented as a
  complete replacement for DCMI's published Qualified Dublin Core schemas.

  DCMI schema reference: https://www.dublincore.org/schemas/xmls/qdc/
-->
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema"
           targetNamespace="http://purl.org/dc/terms/"
           xmlns:dcterms="http://purl.org/dc/terms/"
           elementFormDefault="qualified"
           attributeFormDefault="unqualified"
           version="1.0">
  <xs:annotation>
    <xs:documentation>Minimal imported validation profile for dcterms:identifier and dcterms:description.</xs:documentation>
  </xs:annotation>

  <xs:element name="identifier" type="xs:string">
    <xs:annotation>
      <xs:documentation>An unambiguous reference to the resource within a given context.</xs:documentation>
    </xs:annotation>
  </xs:element>

  <xs:element name="description" type="xs:string">
    <xs:annotation>
      <xs:documentation>An account of the resource.</xs:documentation>
    </xs:annotation>
  </xs:element>
</xs:schema>
